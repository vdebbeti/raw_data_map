16
17   proc sort data = raw.dm (keep = usubjid rfstdtc siteid) out = work.dm_ref;
NOTE: There were 312 observations read from the data set RAW.DM.
18     by usubjid;
19   run;
NOTE: The data set WORK.DM_REF has 312 observations and 3 variables.

20
21   data work.ae_mapped;
22     merge work.ae_input (in=a)
23           work.dm_ref   (in=b);
24     by usubjid;
25     if a;
26
27     STUDYID  = "STUDY001";
28     DOMAIN   = "AE";
29     AESEQ    = _N_;
NOTE: The data set WORK.AE_MAPPED has 2803 observations and 31 variables.

30
31   data sdtm.ae;
